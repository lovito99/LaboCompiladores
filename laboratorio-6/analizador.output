    $end (0) 0
    '(' (40) 25 26 28 29 30 33 48
    ')' (41) 25 26 28 29 30 33 48
    '*' (42) 45
    '+' (43) 43
    ',' (44) 23
    '-' (45) 44 47
    '/' (47) 46
    ';' (59) 9 10 11 12 13 17
    '<' (60) 38
    '=' (61) 24
    '>' (62) 37
    '{' (123) 27
    '}' (125) 27
    error (256) 7 17
    IDENTIFICADOR <sval> (258) 22 23 24 25 50
    NUMERO <ival> (259) 49
    BOOL_LITERAL <ival> (260) 32
    INT (261) 19
    FLOAT (262) 20
    BOOL (263) 21
    IF (264) 28 29
    ELSE (265) 29
    WHILE (266) 30
    READ (267) 25
    PRINT (268) 26
