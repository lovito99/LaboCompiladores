Gramática

    0 $accept: programa $end

    1 programa: lista_sentencias

    2 lista_sentencias: ε
    3                 | lista_sentencias sentencia

    4 sentencia: declaracion ';'
    5          | asignacion ';'
    6          | lectura ';'
    7          | escritura ';'
    8          | bloque
    9          | seleccion
   10          | iteracion
   11          | error ';'

   12 declaracion: tipo lista_identificadores

   13 tipo: INT
   14     | FLOAT
   15     | BOOL

   16 lista_identificadores: IDENTIFICADOR
   17                      | lista_identificadores ',' IDENTIFICADOR

   18 asignacion: IDENTIFICADOR '=' expresion

   19 lectura: READ '(' IDENTIFICADOR ')'

   20 escritura: PRINT '(' expresion ')'

   21 bloque: '{' lista_sentencias '}'

   22 seleccion: IF '(' condicion ')' sentencia
   23          | IF '(' condicion ')' sentencia ELSE sentencia

   24 iteracion: WHILE '(' condicion ')' sentencia

   25 condicion: expresion operador_relacional expresion
   26          | BOOL_LITERAL
   27          | '(' condicion ')'
   28          | NOT condicion
   29          | condicion AND condicion
   30          | condicion OR condicion

   31 operador_relacional: '>'
   32                    | '<'
   33                    | GE
   34                    | LE
   35                    | EQ
   36                    | NE

   37 expresion: expresion '+' expresion
   38          | expresion '-' expresion
   39          | expresion '*' expresion
   40          | expresion '/' expresion
   41          | '-' expresion
   42          | '(' expresion ')'
   43          | NUMERO
   44          | IDENTIFICADOR


