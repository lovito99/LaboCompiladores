Grammar

    0 $accept: programa $end

    1 programa: lista_elementos

    2 lista_elementos: ε
    3                | lista_elementos FIN_LINEA
    4                | lista_elementos elemento

    5 elemento: sentencia
    6         | expresion_suelta
    7         | error FIN_LINEA

    8 expresion_suelta: expresion FIN_LINEA
    9                 | expresion ';'

   10 sentencia: declaracion ';'
   11          | asignacion ';'
   12          | lectura ';'
   13          | escritura ';'
   14          | bloque
   15          | seleccion
   16          | iteracion
   17          | error ';'

   18 declaracion: tipo lista_identificadores

   19 tipo: INT
   20     | FLOAT
   21     | BOOL

   22 lista_identificadores: IDENTIFICADOR
   23                      | lista_identificadores ',' IDENTIFICADOR

   24 asignacion: IDENTIFICADOR '=' expresion

   25 lectura: READ '(' IDENTIFICADOR ')'

   26 escritura: PRINT '(' expresion ')'

   27 bloque: '{' lista_elementos '}'

   28 seleccion: IF '(' condicion ')' sentencia
   29          | IF '(' condicion ')' sentencia ELSE sentencia

   30 iteracion: WHILE '(' condicion ')' sentencia

   31 condicion: expresion operador_relacional expresion
   32          | BOOL_LITERAL
   33          | '(' condicion ')'
   34          | NOT condicion
   35          | condicion AND condicion
   36          | condicion OR condicion

   37 operador_relacional: '>'
   38                    | '<'
   39                    | GE
   40                    | LE
   41                    | EQ
   42                    | NE

   43 expresion: expresion '+' expresion
   44          | expresion '-' expresion
   45          | expresion '*' expresion
   46          | expresion '/' expresion
   47          | '-' expresion
   48          | '(' expresion ')'
   49          | NUMERO
   50          | IDENTIFICADOR


